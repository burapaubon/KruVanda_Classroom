function doPost(e) {
  var jsonOutput = ContentService.createTextOutput();

  try {
    var requestData = JSON.parse(e.postData.contents);
    var inputUser = requestData.username;
    var inputPass = requestData.password;

    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var userSheet = ss.getSheetByName("User_Accounts");
    var userRows = userSheet.getDataRange().getValues();

    var loginSuccess = false;
    var userData = null;

    for (var i = 1; i < userRows.length; i++) {
      var userId = userRows[i][0]
      var username = userRows[i][1]
      var password = userRows[i][2]
      var role = userRows[i][3]

      if (String(username).trim() === String(inputUser).trim() && String(password) === String(inputPass)) {
        loginSuccess = true;
        userData = {
          userId: userId,
          role: role
        };
        break;
      }
    }

    if (loginSuccess) {
      if (userData.role === "student") {
        var studentSheet = ss.getSheetByName("Student_Profiles");
        var studentRows = studentSheet.getDataRange().getValues();

        for (var j = 1; j < studentRows.length; j++) {
          if (studentRows[j][0] === userData.userId) {
            userData.firstName = studentRows[j][1];
            userData.lastName = studentRows[j][2];
            userData.room = studentRows[j][3];
            userData.no = studentRows[j][4];
            userData.year = studentRows[j][5];
            userData.imgUrl = studentRows[j][6];
            break;
          }
        }
      } else if (userData.role === "teacher") {
        var teacherSheet = ss.getSheetByName("Teacher_Profile");
        var teacherRows = teacherSheet.getDataRange().getValues();

        if (teacherRows.length > 1) {
          userData.fullName = teacherRows[1][1];
          userData.imgUrl = teacherRows[1][3];
        }
      }

      var responseData = { "status": "success", "data": userData };
      return jsonOutput.setMimeType(ContentService.MimeType.JSON)
        .setContent(JSON.stringify(responseData));

    } else {
      var failData = { "status": "fail", "message": "Username หรือ Password ไม่ถูกต้อง!" };
      return jsonOutput.setMimeType(ContentService.MimeType.JSON)
        .setContent(JSON.stringify(failData));
    }

  } catch (error) {
    var errorData = { "status": "error", "message": "เกิดข้อผิดพลาด: " + error.toString() };
    return jsonOutput.setMimeType(ContentService.MimeType.JSON)
      .setContent(JSON.stringify(errorData));
  }
}